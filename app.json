{
  "expo": {
    "name": "SwipeClean",
    "slug": "swipeclean-free",
    "scheme": "swipeclean",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swipeclean.free",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "SwipeClean needs media access so you can review and clean your photos and videos.",
        "NSPhotoLibraryAddUsageDescription": "SwipeClean saves only when you choose to restore or share photos."
      }
    },
    "android": {
      "package": "com.swipeclean.free",
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_DATA_SYNC",
        "com.android.vending.BILLING"
      ]
    },
    "plugins": [
      "expo-router",
      "react-native-compressor",
      [
        "expo-notifications",
        {
          "color": "#075ec8"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "SwipeClean needs media access so you can review and clean your photos and videos.",
          "savePhotosPermission": "SwipeClean saves only when you choose to restore or share photos.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-video",
        {
          "supportsPictureInPicture": true
        }
      ],
      "expo-localization",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow SwipeClean to use Face ID to unlock the app."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5256708773143000~5412947073",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SwipeClean needs media access so you can pick a photo or video to compress."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "43f1c63e-b92b-47c7-a794-b3d499b2f4fa"
      }
    },
    "owner": "mosutermo"
  }
}
