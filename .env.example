# RevenueCat public SDK keys.
# Copy this file to .env.local. Do not commit real local env files.

# Development-only RevenueCat Test Store key. Use this before Google Play /
# App Store products are configured. Never ship a store build with this flag on.
EXPO_PUBLIC_REVENUECAT_USE_TEST_STORE=
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY=

# Real app-specific public SDK keys from RevenueCat Project settings > API keys.
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
